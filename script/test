#!/usr/bin/env bash
# prove_it: full test suite — runs before every git commit.
# Enforces 100% line coverage on the Splint target as a forcing function.
# Override with SPLINT_COVERAGE_THRESHOLD=<n> (0-100). See README ## Coverage.
set -euo pipefail
trap 'rc=$?; command -v prove_it >/dev/null 2>&1 && prove_it record --name full-tests --result $rc' EXIT
cd "$(dirname "$0")/.."

THRESHOLD="${SPLINT_COVERAGE_THRESHOLD:-100}"

# Self-test the marker parser and coverage math before running the suite.
# Fails fast if the gate tooling is broken without wasting a Swift build.
python3 script/lib/coverage.py --self-test

# Run instrumented tests. Not parallel: parallel + coverage historically
# produces per-worker profraws that need merging.
swift test --enable-code-coverage

# Locate the profdata and test binary. swift test puts them here on Swift 6.x.
PROFDATA="$(find .build -name default.profdata -path '*codecov*' | head -1)"
BINARY="$(find .build -name 'SplintPackageTests' -type f -perm +111 | head -1)"
[[ -f "$PROFDATA" ]] || { echo "error: default.profdata not found" >&2; exit 2; }
[[ -x "$BINARY"  ]] || { echo "error: SplintPackageTests binary not found" >&2; exit 2; }

# Export per-line coverage in lcov format (DA:line,count is authoritative)
# and pipe through the coverage gate.
xcrun llvm-cov export -format=lcov -instr-profile="$PROFDATA" "$BINARY" \
  | python3 script/lib/coverage.py "$THRESHOLD"

# Example app: compile BookshelfApp (via .executableTarget) and run the
# swift-testing suite. No coverage gate — the 100% threshold scopes to
# Sources/Splint/ only (see CLAUDE.md). The .xcodeproj is the runnable
# entry point for humans.
#
# Skipped in CI: Xcode 26.3's SDK emits SwiftUI internal symbols (e.g.
# `_TagTraitWritingModifier`) that only exist in macOS 26.2+ SwiftUI
# runtime, and GitHub's macos-latest runner is on an older OS. Root
# Splint tests don't use SwiftUI so they link cleanly; Example does.
# Runs locally on any Xcode 26.4 machine (which matches its runtime).
if [[ "${CI:-}" == "true" ]]; then
  echo "script/test: CI environment — skipping Example test suite (SwiftUI runtime compat; see script comment)"
else
  (cd Example && swift test)
fi
